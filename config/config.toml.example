# ============================================================
# DataOrcid-Chile — Configuration Example File
# Author: Gastón Olivares
# License: MIT
# ============================================================
# This file is a configuration template.
# Copy it to `config/config.toml` and adjust values for your environment.
# ============================================================


# ------------------------------------------------------------
# 🔹 DATABASE
# ------------------------------------------------------------
[database]
# Format: dialect+driver://user:password@host/dbname
# MySQL:
uri = "mysql+pymysql://USER:PASS@localhost/dataorcid_chile"
# PostgreSQL:
# uri = "postgresql+psycopg://USER:PASS@localhost:5432/dataorcid_chile"


# ------------------------------------------------------------
# 🔹 FLASK CONFIGURATION
# ------------------------------------------------------------
[flask]
secret_key = "CHANGEME_IN_RUNTIME"
password_salt = "CHANGE_ME_SALT"
session_cookie_secure = true
session_cookie_httponly = true
session_cookie_samesite = "Lax"


# ------------------------------------------------------------
# 🔹 LANGUAGES (i18n)
# ------------------------------------------------------------
[languages]
supported = ["es", "en"]
default = "es"


# ------------------------------------------------------------
# 🔹 INTERNAL PATHS
# ------------------------------------------------------------
[paths]
datasets_dir = "app/datasets"


# ------------------------------------------------------------
# 🔹 GENERAL APP CONFIGURATION
# ------------------------------------------------------------
[app]
base_url = "http://localhost:5000"


# ------------------------------------------------------------
# 🔹 ORCID CONFIGURATION
# ------------------------------------------------------------
[orcid]
base_url_public  = "https://pub.orcid.org/v3.0/"
base_url_member  = "https://api.orcid.org/v3.0/"
token_url      = "https://orcid.org/oauth/token"
client_id      = "APP-XXXXXX"
client_secret = "REPLACE_OR_USE_ENV"


# ------------------------------------------------------------
# 🔹 OPENALEX CONFIGURATION
# ------------------------------------------------------------
[openalex]
base_url = "https://api.openalex.org"
# Prefer the OPENALEX_API_KEY environment variable in production.
api_key = "REPLACE_OR_USE_ENV"
# Optional contact email for operational follow-up.
mailto = "support@your-domain.cl"
timeout = 20
stale_days = 30
# Parallel DOI fetch workers for OpenAlex sync. Start with 4; raise carefully.
workers = 4
# Title fallback is heavier than DOI lookup; keep it lower to avoid 429s.
title_workers = 2
# Seconds to keep global OpenAlex analytics in memory per worker and filter set.
analytics_cache_ttl = 900


# ------------------------------------------------------------
# 🔹 EMAIL CONFIGURATION (SMTP)
# ------------------------------------------------------------
[mail]
enabled      = true
smtp_host    = "smtp.gmail.com"
smtp_port    = 587
use_tls      = true
use_ssl      = false
smtp_user    = "your-email@cincel.cl"
smtp_pass    = "your-app-password"
from_name    = "Data ORCID-Chile"
from_email   = "your-email@cincel.cl"
reply_to     = "support@your-domain.cl"
